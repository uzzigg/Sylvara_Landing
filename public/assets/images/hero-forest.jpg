  <text x="600" y="440" font-family="Arial, sans-serif" font-size="24" fill="#F1F5F9" text-anchor="middle" opacity="0.6">
    hero-forest.jpg
  </text>
  <text x="600" y="480" font-family="Arial, sans-serif" font-size="18" fill="#F1F5F9" text-anchor="middle" opacity="0.5">
